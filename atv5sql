CREATE TABLE func (
    id_funcionario    NUMBER GENERATED ALWAYS AS IDENTITY,
    cpf               VARCHAR2(14),
    first_name        VARCHAR2(100),
    last_name         VARCHAR2(100),
    idade             NUMBER(3),
    sexo              CHAR(1),
    cargo             VARCHAR2(100),
    id_unidade        NUMBER,
    id_departamento   NUMBER,

    -- Note que mudei os nomes abaixo para evitar o erro ORA-00955
    CONSTRAINT pk_func PRIMARY KEY (id_funcionario),
    CONSTRAINT uk_cpf_func UNIQUE (cpf),
    CONSTRAINT ck_func_sexo_v2 CHECK (sexo IN ('M', 'F')),

    CONSTRAINT fgk_unidade_func 
        FOREIGN KEY (id_unidade) 
        REFERENCES unidade(id),

    CONSTRAINT fgk_depto_func 
        FOREIGN KEY (id_departamento) 
        REFERENCES departamentos(id_departamento)
);

