BEGIN
  FOR i IN 1..100 LOOP
    INSERT INTO func (
        cpf, 
        first_name, 
        last_name, 
        idade, 
        sexo, 
        cargo, 
        data_nasc, 
        salario, 
        id_departamento, 
        id_unidade
    ) VALUES (
        -- Gera CPF fictício: 000.000.000-00 (variando o final com o índice i)
        LPAD(TRUNC(DBMS_RANDOM.VALUE(100,999)), 3, '0') || '.' || 
        LPAD(TRUNC(DBMS_RANDOM.VALUE(100,999)), 3, '0') || '.' || 
        LPAD(TRUNC(DBMS_RANDOM.VALUE(100,999)), 3, '0') || '-' || 
        LPAD(MOD(i, 99), 2, '0'),
        
        -- Nomes aleatórios
        CASE MOD(i, 5) 
            WHEN 0 THEN 'Ricardo' WHEN 1 THEN 'Luciana' 
            WHEN 2 THEN 'Marcos'  WHEN 3 THEN 'Adriana' ELSE 'Sérgio' END,
        
        CASE MOD(i, 4) 
            WHEN 0 THEN 'Pereira' WHEN 1 THEN 'Gomes' 
            WHEN 2 THEN 'Ferreira' ELSE 'Alves' END,
        
        -- Idade entre 25 e 55 anos
        TRUNC(DBMS_RANDOM.VALUE(25, 55)),
        
        -- Sexo aleatório
        CASE WHEN DBMS_RANDOM.VALUE > 0.5 THEN 'M' ELSE 'F' END,
        
        -- Cargos Reais de um CASE
        CASE MOD(i, 6)
            WHEN 0 THEN 'Agente de Segurança Socioeducativo'
            WHEN 1 THEN 'Assistente Social'
            WHEN 2 THEN 'Psicólogo'
            WHEN 3 THEN 'Pedagogo'
            WHEN 4 THEN 'Oficial de Inteligência'
            ELSE 'Coordenador de Unidade' END,
        
        -- Data de Nascimento (Baseada na idade gerada acima)
        ADD_MONTHS(SYSDATE, - (TRUNC(DBMS_RANDOM.VALUE(25, 55)) * 12)),
        
        -- Salário entre 4000 e 8000
        TRUNC(DBMS_RANDOM.VALUE(4000, 8000), 2),
        
        -- ID Departamento: Aleatório entre 1 e 20
        TRUNC(DBMS_RANDOM.VALUE(1, 21)),
        
        -- ID Unidade: Aleatório entre 21 e 30
        TRUNC(DBMS_RANDOM.VALUE(21, 31))
    );
  END LOOP;
  
  COMMIT;
END;
